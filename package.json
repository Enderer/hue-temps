{
  "name": "huetemps",
  "version": "2.0.0",
  "description": "CLI to control Philips Hue lights",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enderer/hue-temps"
  },
  "homepage": "https://github.com/Enderer/hue-temps",
  "bugs": {
    "url": "https://github.com/Enderer/hue-temps/issues"
  },
  "type": "module",
  "bin": {
    "huetemps": "dist/src/bin/huetemps.js"
  },
  "exports": "./dist/src/cli/index.js",
  "main": "./dist/src/cli/index.js",
  "files": [
    "dist",
    "assets"
  ],
  "c8": {
    "exclude": [
      "dist/**/*.test.js",
      "dist/src/**/index.js",
      "dist/src/bin/huetemps.js"
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "copy:package-json": "node -e \"require('fs').copyFileSync('package.json','dist/package.json')\"",
    "copy:assets": "node build/copy-assets.js",
    "write-version": "node ./build/write-version.js",
    "build": "npm run clean && tsc -p tsconfig.json && npm run copy:package-json && npm run copy:assets",
    "dev": "npm run clean && tsc -p tsconfig.json --watch",
    "start": "node dist/src/bin/huetemps.js",
    "prepare": "npm run build",
    "gen-splash": "npm run build && node ./build/render-svg.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "c8": "10.1.3",
    "concurrently": "^9.1.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "globals": "16.5.0",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.49.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "got": "14.6.5",
    "keytar": "^7.9.0",
    "table": "6.9.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.3.4"
  }
}
