{
  "name": "huetemps",
  "version": "0.1.0",
  "description": "CLI to control Philips Hue lights",
  "type": "module",
  "bin": {
    "huetemps": "./dist/src/cli/index.js"
  },
  "exports": "./dist/src/cli/index.js",
  "main": "./dist/src/cli/index.js",
  "files": [
    "dist"
  ],
  "c8": {
    "exclude": [
      "dist/**/*.test.js",
      "dist/src/**/index.js"
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "npm run clean && tsc -p tsconfig.json --watch",
    "start": "node dist/src/cli/index.js",
    "prepare": "npm run build",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "npm run build && c8 --all --include=dist/src/**/*.js node --test dist/**/*.test.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "c8": "10.1.3",
    "concurrently": "^9.1.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "globals": "16.5.0",
    "prettier": "^3.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.49.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "got": "14.6.5",
    "table": "6.9.0",
    "yaml": "^2.3.4"
  }
}
